<Window x:Class="GaokaoCountdown.WeatherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="天气"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="False"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing">

    <!-- 单一容器：代码中根据模式切换背景/边框/圆角/阴影 -->
    <Border x:Name="MainBorder" Background="Transparent"
            BorderThickness="0" CornerRadius="0"
            Padding="4,2,4,2">

        <Grid x:Name="ContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 第一行：天气图标 + 地点 + 天气 + 温度 -->
            <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                <TextBlock x:Name="WeatherIconTb" Text="☀"
                           FontSize="22" Foreground="#FFFFAA00"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="CityTb" Text="--"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="#FFFFFFFF"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="WeatherTb" Text="--"
                           FontSize="14"
                           Foreground="#FFCCCCDD"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="TempTb" Text="--°C"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#FFFF8844"
                           VerticalAlignment="Center"/>
            </WrapPanel>

            <!-- 第二行：风向风力 + 湿度 + 更新时间 -->
            <WrapPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,2,0,0">
                <TextBlock x:Name="WindTb" Text="--"
                           FontSize="12" Foreground="#88CCCCDD"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="HumidityTb" Text="--"
                           FontSize="12" Foreground="#88CCCCDD"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="ReportTimeTb" Text="--"
                           FontSize="11" Foreground="#66AAAAAA"
                           VerticalAlignment="Center"/>
            </WrapPanel>
        </Grid>
    </Border>
</Window>
